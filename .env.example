# Copy to .env and fill in your own key. .env is gitignored.
# Get a key at https://platform.kimi.com/console/account
KIMI_API_KEY=sk-your-kimi-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Backend port (frontend talks to it via the Vite /api proxy in dev).
PORT=8787

# TinyPNG — only for scripts/compress-images.mjs. Get a free key at
# https://tinypng.com/developers
TINYPNG_API_KEY=your-tinypng-key-here
